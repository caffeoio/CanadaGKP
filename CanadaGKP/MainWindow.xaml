                                        <WrapPanel Margin="0 10 0 0">
                                            <Border Style="{StaticResource InteractiveBorderStyle}" Width="170" Height="60" Background="{StaticResource ActionBackgroundBrush}" BorderBrush="{StaticResource StrokeBrush}" BorderThickness="1" Name="LOpenBTDY_R">
                                                <TextBlock VerticalAlignment="Center" HorizontalAlignment="Center"  Foreground="{StaticResource TextPrimaryBrush}" Block.TextAlignment="Center" FontSize="20" Name="R_BTSD" MouseDown="R_BTSD_MouseDown">Robot Power On</TextBlock>
                                            </Border>
                                            <Border Style="{StaticResource InteractiveBorderStyle}" Width="170" Height="60" Background="{StaticResource ActionBackgroundBrush}" BorderBrush="{StaticResource StrokeBrush}" BorderThickness="1" Block.TextAlignment="Center" Margin="20 0 0 0" Name="LCloseBTDY_R">
                                                <TextBlock VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="{StaticResource TextPrimaryBrush}" FontSize="20" Name="R_BTXD" MouseDown="R_BTXD_MouseDown">Robot Power Off</TextBlock>
                                            </Border>
                                        </WrapPanel>
                                        <WrapPanel Margin="0 10 0 0">
                                            <Border Style="{StaticResource InteractiveBorderStyle}" Width="170" Height="60" Block.TextAlignment="Center" Background="{StaticResource ActionBackgroundBrush}" BorderBrush="{StaticResource StrokeBrush}" BorderThickness="1" Name="LOpenSSN_R">
                                                <TextBlock VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="{StaticResource TextPrimaryBrush}" FontSize="20" Name="R_SSN" MouseDown="R_SSN_MouseDown">Enable</TextBlock>
                                            </Border>
                                            <Border Style="{StaticResource InteractiveBorderStyle}" Width="170" Height="60" Block.TextAlignment="Center" Background="{StaticResource ActionBackgroundBrush}" BorderBrush="{StaticResource StrokeBrush}" BorderThickness="1" Margin="20 0 0 0" Name="LCloseSSN_R">
                                                <TextBlock VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="{StaticResource TextPrimaryBrush}" FontSize="20" Name="R_XSN" MouseDown="R_XSN_MouseDown">Disable</TextBlock>
                                            </Border>
                                        </WrapPanel>
                                        <WrapPanel Margin="0 10 0 0">
                                            <Border Style="{StaticResource InteractiveBorderStyle}" Width="170" Height="60" Block.TextAlignment="Center" Background="{StaticResource ActionBackgroundBrush}" BorderBrush="{StaticResource StrokeBrush}" BorderThickness="1" Name="LOpenYXCX_R">
                                                <TextBlock VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="{StaticResource TextPrimaryBrush}" FontSize="20" Name="R_YXCX" MouseDown="R_YXCX_MouseDown">Run Program</TextBlock>
                                            </Border>
                                            <Border Style="{StaticResource InteractiveBorderStyle}" Width="170" Height="60" Block.TextAlignment="Center" Background="{StaticResource ActionBackgroundBrush}" BorderBrush="{StaticResource StrokeBrush}" BorderThickness="1" Margin="20 0 0 0" Name="LCloseTZCX_R">
                                                <TextBlock VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="{StaticResource TextPrimaryBrush}" FontSize="20" Name="R_TZCX" MouseDown="R_TZCX_MouseDown">Stop Program</TextBlock>
                                            </Border>
                                        </WrapPanel>
                                        <WrapPanel Margin="0 10 0 0">
                                            <Border Style="{StaticResource InteractiveBorderStyle}" Width="170" Height="60" Background="{StaticResource ActionBackgroundBrush}" BorderBrush="{StaticResource StrokeBrush}" BorderThickness="1" Block.TextAlignment="Center" Name="LContinueZTCX_R">
                                                <TextBlock VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="{StaticResource TextPrimaryBrush}" FontSize="20" Name="R_ZTCX" MouseDown="R_ZTCX_MouseDown">Pause Program</TextBlock>
                                            </Border>
                                            <Border Style="{StaticResource InteractiveBorderStyle}" Width="170" Height="60" Block.TextAlignment="Center" Background="{StaticResource ActionBackgroundBrush}" BorderBrush="{StaticResource StrokeBrush}" BorderThickness="1" Margin="20 0 0 0" Name="LCloseJXCX_R">
                                                <TextBlock VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="{StaticResource TextPrimaryBrush}" FontSize="20" Name="R_JXCX" MouseDown="R_JXCX_MouseDown">Resume Program</TextBlock>
                                            </Border>
                                        </WrapPanel>
                                    </StackPanel>
                                </Grid>
                            </Grid>
                            <Border Background="{StaticResource PanelAccentBrush}" Grid.Column="1"/>
                        </Grid>
                        <Grid Grid.Row="2" Name="MiMa" Background="{StaticResource AppBackgroundBrush}" Visibility="Collapsed">
                            <StackPanel VerticalAlignment="Center">
                                <WrapPanel HorizontalAlignment="Center">
                                    <TextBlock Foreground="{StaticResource TextPrimaryBrush}" FontSize="20" Block.TextAlignment="Center" VerticalAlignment="Center">Password</TextBlock>
                                    <TextBox Margin="10 0" Width="200" Name="pas" VerticalContentAlignment="Center" FontSize="20"/>
                                </WrapPanel>
                                <WrapPanel HorizontalAlignment="Center" Margin="40">
                                    <Button Width="100" Height="60" Margin="0 0 10 0"  Background="{StaticResource ActionBackgroundBrush}" Click="Button_Click">
                                        <TextBlock  Foreground="{StaticResource TextPrimaryBrush}" Block.TextAlignment="Center" Tag="0" VerticalAlignment="Center" FontSize="20">Cancel</TextBlock>
                                    </Button>
                                    <Button Width="100" Height="60" Margin="70 0 10 0"  Background="{StaticResource ActionBackgroundBrush}" Click="Button_Click_1">
                                        <TextBlock  Foreground="{StaticResource TextPrimaryBrush}" Block.TextAlignment="Center" Tag="0" VerticalAlignment="Center" FontSize="20">Confirm</TextBlock>
                                    </Button>
                                </WrapPanel>
                            </StackPanel>

                        </Grid>
                    </Grid>
                </Grid>
            </Border>

            <WrapPanel Grid.Row="2" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="10 0">
                <Border Style="{StaticResource InteractiveBorderStyle}" Width="250" BorderBrush="{StaticResource StrokeBrush}" Background="{StaticResource SectionBackgroundBrush}" Height="70" Block.TextAlignment="Center" BorderThickness="3" Name="show" Margin="20 0" MouseDown="show_MouseDown">
                    <TextBlock VerticalAlignment="Center" HorizontalAlignment="Center"  Foreground="{StaticResource TextPrimaryBrush}" FontSize="25">JAKA Control</TextBlock>
                </Border>
                <Border Style="{StaticResource InteractiveBorderStyle}" Width="230" BorderBrush="{StaticResource StrokeBrush}" Background="{StaticResource SectionBackgroundBrush}" Height="70" BorderThickness="3" Block.TextAlignment="Center" Name="control1"  MouseDown="control1_MouseDown">
                    <TextBlock VerticalAlignment="Center" HorizontalAlignment="Center"  Foreground="{StaticResource TextPrimaryBrush}" FontSize="25">Machine Control</TextBlock>
                </Border>
                <Border Style="{StaticResource InteractiveBorderStyle}" Width="230" BorderBrush="{StaticResource StrokeBrush}" Background="{StaticResource SectionBackgroundBrush}" Height="70" BorderThickness="3" Block.TextAlignment="Center" Name="control2" Margin="20 0" MouseDown="control2_MouseDown">
                    <TextBlock VerticalAlignment="Center" HorizontalAlignment="Center"  Foreground="{StaticResource TextPrimaryBrush}" FontSize="25">Machine Status</TextBlock>
                </Border>
            </WrapPanel>
        </Grid>
    </Grid>
</Window>






